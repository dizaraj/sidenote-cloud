{
    "manifest_version": 3,
    "name": "SideNote Cloud",
    "version": "1.0",
    "description": "Create and sync notes directly from the sidebar to Supabase.",
    "permissions": [
        "sidePanel",
        "storage"
    ],
    "host_permissions": [
        "*://*.supabase.co/*"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "side_panel": {
        "default_path": "sidebar.html"
    },
    "action": {
        "default_title": "Toggle SideNote Cloud"
    },
    "options_page": "options.html"
}